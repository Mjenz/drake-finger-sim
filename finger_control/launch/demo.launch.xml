<launch>
  <arg name="use_rviz" default="true" description="Enable the use of rviz for visualization.">
    <choice value="true" />
    <choice value="false" />
  </arg>

  <arg name="bridge" default="simulation" description="Select bridge to deploy.">
    <choice value="simulation" />
    <choice value="hardware" />
  </arg>

  <arg name="record" default="false" description="Enable the bagging of joint and motor position data.">
    <choice value="true" />
    <choice value="false" />
  </arg>

  <arg name="demo" default="none" description="Select the demo to run.">
    <choice value="force_step" />
    <choice value="sinusoidal" />
    <choice value="linear" />
    <choice value="ik" />
    <choice value="cartesian_ik" />
    <choice value="none" />
  </arg>
  
  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_simulation)/config/base_sim.rviz" if="$(eval '\'$(var use_rviz)\'==\'true\'')" on_exit="shutdown"/>  

  <node pkg="finger_simulation" exec="basic" namespace="actual" if="$(eval '\'$(var bridge)\'==\'hardware\'')">
    <remap from="/scene_markers/visual" to="/actual/scene_markers/visual"/>
    <remap from="/scene_markers/collision" to="/actual/scene_markers/collision"/>
  </node>

  <node pkg="finger_simulation" exec="4barsim" namespace="drake" output="screen" if="$(eval '\'$(var bridge)\'==\'simulation\'')">
    <remap from="/scene_markers/visual" to="/drake/scene_markers/visual"/>
    <remap from="/scene_markers/collision" to="/drake/scene_markers/collision"/>
  </node>

  <node pkg="finger_simulation" exec="basic_setpoint" namespace="setpoint">
    <remap from="motor_pos_actual_feedback" to="motor_pos_setpoint_feedback"/>
    <remap from="/scene_markers/visual" to="/setpoint/scene_markers/visual"/>
    <remap from="/scene_markers/collision" to="/setpoint/scene_markers/collision"/>
  </node>

  <node pkg="finger_bridge" exec="simulation_bridge" output="screen" if="$(eval '\'$(var bridge)\'==\'simulation\'')"/>
  <node pkg="finger_bridge" exec="hardware_bridge" output="screen" if="$(eval '\'$(var bridge)\'==\'hardware\'')"/>

  <node pkg="finger_planner" exec="finger_planner" output="screen">
    <param from="$(find-pkg-share finger_description)/config/finger.yaml"/>
    <param from="$(find-pkg-share finger_planner)/config/movement_config.yaml"/>
  </node>

  <node pkg="finger_control" exec="demo" output="screen">
      <param from="$(find-pkg-share finger_description)/config/finger.yaml"/>
      <param from="$(find-pkg-share finger_planner)/config/movement_config.yaml"/>
      <param name="demo" value="$(var demo)" />
  </node>

  <node pkg="finger_recorder" exec="record" if="$(eval '\'$(var record)\'==\'true\'')" output="screen"/>


</launch>
