<launch>
  <arg name="use_rviz" default="true" description="Enable the use of rviz for visualization.">
    <choice value="true" />
    <choice value="false" />
  </arg>

  <arg name="record" default="false" description="Enable the bagging of joint and motor position data.">
    <choice value="true" />
    <choice value="false" />
  </arg>
  
  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_control)/config/sim_whackamole.rviz" if="$(eval '\'$(var use_rviz)\'==\'true\'')" on_exit="shutdown"/>  

  <node pkg="finger_simulation" exec="basic" namespace="actual">
    <remap from="/scene_markers/visual" to="/actual/scene_markers/visual"/>
    <remap from="/scene_markers/collision" to="/actual/scene_markers/collision"/>
  </node>

  <node pkg="finger_simulation" exec="basic_setpoint" namespace="setpoint">
    <remap from="motor_pos_actual_feedback" to="motor_pos_setpoint_feedback"/>
    <remap from="/scene_markers/visual" to="/setpoint/scene_markers/visual"/>
    <remap from="/scene_markers/collision" to="/setpoint/scene_markers/collision"/>
  </node>

  <node pkg="finger_bridge" exec="simulation_bridge" output="screen"/>

  <node pkg="finger_planner" exec="finger_planner" output="screen">
    <param from="$(find-pkg-share finger_description)/config/finger.yaml"/>
    <param from="$(find-pkg-share finger_planner)/config/movement_config.yaml"/>
  </node>

  <node pkg="finger_control" exec="control" output="screen">
      <param from="$(find-pkg-share finger_description)/config/finger.yaml"/>
      <param from="$(find-pkg-share finger_planner)/config/movement_config.yaml"/>
  </node>

  <node pkg="finger_recorder" exec="record" if="$(eval '\'$(var record)\'==\'true\'')" output="screen"/>

  <node pkg="tf2_ros" exec="static_transform_publisher"
       args="--x 0 --y 0 --z 0.2 --qx 0 --qy 0 --qz 0 --qw 1 --frame-id world --child-frame-id base_frame" />

  <node pkg="finger_vision2" exec="simulation_vision" output="screen">
    <param from="$(find-pkg-share finger_description)/config/finger.yaml"/>
  </node>

</launch>
