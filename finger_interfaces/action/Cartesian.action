# Action message type to generate and command cartesian motion from finger
int32 length    # The number of waypoints
int32 repeat    # Boolean to indicate trajectory should be repeated by controller (1 for repeat, 0 for not)
float32[] x     # Array of waypoint x positions in cartesian space
float32[] y     # Array of waypoint y positions in cartesian space
float32[] z     # Array of waypoint z positions in cartesian space
---
int32 success
---
float32[] state
